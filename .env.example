# Discord API token from the Discord Developer Portal
TOKEN= (api token)
CLIENT_ID= (app id)
GUILD_ID= (discord server id)
# Customizable currency settings
CURRENCY_NAME=           # The name of your currency (e.g., bolts, gems, coins)
CURRENCY_SYMBOL=         # The symbol of your currency (e.g., ⚡, 💎, 🪙)

# Customizable help command
HELP_COMMAND=            # The command name for the help message (e.g., pizzahelp)

# Database configuration (if applicable)
DB_FILE=database.db      # Path to the SQLite database file

# Additional bot settings
PREFIX=$                 # Command prefix for the bot (e.g., $, !, ?)
BOT_NAME=

# Email notification for complete-job
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-email-password
# EMAIL_TO=recipient-email@example.com
